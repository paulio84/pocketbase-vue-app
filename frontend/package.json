{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint . --ext .vue,.js,.ts,.tsx",
        "lint:fix": "eslint . --ext .vue,.js,.ts,.tsx --fix",
        "format": "prettier --write \"src/**/*.{vue,ts,js,json,css}\""
    },
    "dependencies": {
        "@heroicons/vue": "^2.2.0",
        "@tailwindcss/vite": "^4.2.2",
        "tailwindcss": "^4.2.2",
        "vue": "^3.5.21"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.5.0",
        "@vitejs/plugin-vue": "^6.0.1",
        "@vue/tsconfig": "^0.8.1",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-vue": "^10.8.0",
        "prettier": "^3.8.1",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^7.1.7",
        "vue-tsc": "^3.0.7"
    }
